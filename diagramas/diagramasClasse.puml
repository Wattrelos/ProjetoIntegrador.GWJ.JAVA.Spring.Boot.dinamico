@startuml
 
skinparam monochrome true
skinparam classAttributeIconSize 0

title Diagrama de Classes - Projeto Integrador GWJ (Nova Arquitetura)

package com.gwj.controller {
    class GenericViewController {
        +create(entity: String, request: HttpServletRequest, model: Model): String
        +listar(entity: String, request: HttpServletRequest, model: Model): String
        +detalhe(entity: String, request: HttpServletRequest, model: Model): String
        +editar(entity: String, request: HttpServletRequest, model: Model): String
    }

    class JsonController {
        +create(entityName: String, request: HttpServletRequest): ResponseEntity
        +read(entityName: String, request: HttpServletRequest): ResponseEntity
        +update(request: HttpServletRequest): ResponseEntity
        +delete(entityName: String, request: HttpServletRequest): ResponseEntity
    }

    class LoginController {
        +showLoginForm(session: HttpSession): String
        +processLogin(email: String, senha: String, request: HttpServletRequest, model: Model): String
        +logout(request: HttpServletRequest): String
    }

    class Router {
        +home(model: Model): String
        +servico(model: Model): String
        +shop(model: Model): String
        +singleProduct(request: HttpServletRequest, model: Model): String
    }
}

package com.gwj.service {
    interface IService<T> {
        +create(entity: T): T
        +read(entity: T): List<T>
        +update(entity: T): Long
        +delete(entity: T): Long
    }

    class GenericService<T> {
        #repository: IRepository<T>
        +GenericService(entityClass: Class)
        +GenericService(repository: IRepository<T>)
    }

    class UsuarioService {
        +UsuarioService()
    }

    class ServiceRegistry {
        {static} -registry: Map<String, IService>
        {static} +getService(entityName: String): IService<T>
    }
}

package com.gwj.service.transaction {
    class UnitOfWork {
        {static} -currentConnection: ThreadLocal<Connection>
        {static} -inTransaction: ThreadLocal<Boolean>
        {static} +getConnection(): Connection
        {static} +beginTransaction()
        {static} +commit()
        {static} +rollback()
        +close()
    }
}

package com.gwj.model.repository {
    interface IRepository<T> {
        +save(entity: T): T
        +query(entity: T): List<T>
        +update(entity: T): Long
        +delete(entity: T): Long
    }

    class GenericRepository<T> {
        -entityClass: Class<T>
        +GenericRepository(entityClass: Class<T>)
    }

    class UsuarioRepository {
        +UsuarioRepository()
    }
}

package com.gwj.model.dataAccessObject {
    class DataMapper {
        {static} +getEntityHierarchy(startClass: Class): List<Class>
        {static} +getTableName(clazz: Class): String
        {static} +getColumnName(clazz: Class, method: Method, isEntityValue: boolean): String
        {static} +convertToTargetType(value: Object, targetType: Class, field: Field): Object
        {static} +convertPascalCaseToSnakeCase(name: String): String
        {static} +capitalize(str: String): String
    }

    class ConnectionDB {
        {static} -instance: ConnectionDB
        +getConnection(): Connection
        {static} +getInstance(): ConnectionDB
    }

    class QueryBuilder {
        +select(fields: String): QueryBuilder
        +from(table: String): QueryBuilder
        +where(condition: String): QueryBuilder
        +insertInto(table: String): QueryBuilder
        +update(table: String): QueryBuilder
        +build(): String
    }
}

package com.gwj.model.dataTransferObject {
    class EntityMapper {
        {static} +fillEntity(entity: IEntity, request: HttpServletRequest): IEntity
    }
}

package com.gwj.model.domain {
    interface IEntity {
        +getId(): Long
        +setId(id: Long)
    }
}

package com.gwj.model.domain.factory {
    class SimpleObjectFactory {
        {static} +create(name: String): IEntity
    }

    class SchemaValidator {
        {static} +validateAllEntities()
    }
}

' Relacionamentos e Fluxo

' Apresentação para Controle
GenericViewController ..> ServiceRegistry : usa
JsonController ..> ServiceRegistry : usa
LoginController ..> ServiceRegistry : usa
Router ..> ServiceRegistry : usa

GenericViewController ..> EntityMapper : usa
JsonController ..> EntityMapper : usa
Router ..> EntityMapper : usa

' Registro para Serviços
ServiceRegistry o--> IService : gerencia
GenericService ..|> IService
UsuarioService --|> GenericService

' Serviços usam Repositórios e UnitOfWork
GenericService --> IRepository : delega para
GenericService ..> UnitOfWork : controla transação
UsuarioService ..> UsuarioRepository : usa

' Repositórios
GenericRepository ..|> IRepository
UsuarioRepository --|> GenericRepository

' Repositórios acessam conexão via UoW e convertem via DataMapper
GenericRepository ..> UnitOfWork : obtém Connection
GenericRepository ..> DataMapper : realiza mapeamento
GenericRepository ..> QueryBuilder : constrói SQL
DataMapper ..> ConnectionDB : opcional

' Auxiliares de Domínio
EntityMapper ..> IEntity : popula
SimpleObjectFactory ..> IEntity : cria instâncias
SchemaValidator ..> IEntity : valida schema

@enduml
