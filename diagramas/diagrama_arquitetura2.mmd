flowchart TB
    %% Atores e Fontes de Dados
    Client((Cliente<br/>Navegador / App))
    DB[("MySQL / MariaDB<br/>Persistência")]
    Redis[("Redis<br/>Cache / Session Store")]

    %% Camada de Apresentação (Delivery via Slim)
    subgraph Presentation ["Camada de Apresentação (Slim Framework)"]
        direction TB
        Router["Slim Router<br/>(Roteamento)"]
        Middleware["Middleware<br/>(Gerenciador de Sessão / Auth)"]
        Action["Slim Actions<br/>(Single-Action Controllers)"]
        Hydrator["Hydrator<br/>(Monta DTOs)"]
    end

    %% Camada de Aplicação / Domínio
    subgraph Application ["Camada de Aplicação / Domínio"]
        direction TB
        Service["Service Layer<br/>(Casos de Uso / Regras de Negócio)"]
        Repo["Repository<br/>(Contrato de Domínio)"]
    end

    %% Camada de Infraestrutura / Persistência
    subgraph Infrastructure ["Camada de Infraestrutura"]
        direction TB
        Mapper["Data Mapper"]
        DAO["DAO<br/>(Query Builder / UoW)"]
    end

    %% --- FLUXO DE REQUISIÇÃO (HTTP) ---
    Client -- "HTTP Request" --> Router
    Router -- "Despacha" --> Middleware
    Middleware -- "Valida/Injeta Contexto" --> Action
    Action -- "Extrai Payload" --> Hydrator
    
    %% --- INTERAÇÃO COM A SESSÃO ---
    Middleware -. "Lê/Grava Estado da Sessão" .-> Redis

    %% --- FLUXO DE APLICAÇÃO ---
    Hydrator -- "Envia DTOs" --> Service

    %% --- INTERAÇÃO COM O CACHE (Look-Aside Pattern) ---
    Service -. "1. Busca no Cache (Cache Hit)" .-> Redis
    
    %% --- FLUXO DE PERSISTÊNCIA (Cache Miss ou Escrita) ---
    Service -- "2. Cache Miss / Salvar Dados" --> Repo
    Repo -- "Instância de Domínio" --> Mapper
    Mapper -- "Mapeamento" --> DAO
    DAO == "Executa SQL" === DB

    %% Estilização
    classDef layer fill:#f8f9fa,stroke:#adb5bd,stroke-width:2px,stroke-dasharray: 5 5;
    class Presentation,Application,Infrastructure layer;
    
    classDef core fill:#e7f5ff,stroke:#339af0,stroke-width:2px;
    class Router,Middleware,Action,Hydrator,Service,Repo,Mapper,DAO core;
    
    classDef db fill:#d3f9d8,stroke:#2b8a3e,stroke-width:2px;
    class DB,Redis db;